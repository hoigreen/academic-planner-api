{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "Default": "Host=localhost;Port=5432;Database=Audit_School;Username=app_user;Password=app_password",
    "DefaultConnection": "Host=localhost;Port=5432;Database=Audit_School;Username=app_user;Password=app_password"
  },

  "Keycloak": {
    "__comment": "Keycloak is the sole Identity Provider. Authority must be the full realm URL.",
    "Authority": "https://auth.example.com/realms/academic-planner",
    "Audience": "academic-planner-api",
    "ClientId": "academic-planner-web",
    "ValidateAudience": true,
    "RequireHttpsMetadata": true
  }
}
